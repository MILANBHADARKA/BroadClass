{
  "name": "video-call-app",
  "version": "1.0.0",
  "description": "Scalable video call application with WebRTC, WebSocket, and SFU",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "start": "node server/index.js",
    "build:client": "cd client && npm run build"
  },
  "keywords": ["webrtc", "video-call", "mediasoup", "websocket", "sfu"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "mediasoup": "^3.13.0",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}
