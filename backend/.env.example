#  Common 
NODE_ENV=development
LOG_LEVEL=debug   # other: info, warn, error

#  Auth 
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

#  Database 
# Development (local PostgreSQL):
DATABASE_URL=postgresql://user:password@localhost:5432/broadclass

# Production (AWS RDS - uncomment and configure):
# DATABASE_URL=postgresql://admin:YOUR_PASSWORD@broadclass-db.xxxxx.us-east-1.rds.amazonaws.com:5432/broadclass?sslmode=require

#  Redis 
# Development (local Redis):
REDIS_PASSWORD=broadcast123
REDIS_URL=redis://:broadcast123@localhost:6379

# Production (Upstash Redis - uncomment and configure):
# Note: Upstash uses TLS, so use 'rediss://' protocol
# REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@your-endpoint.upstash.io:6379

#  Frontend CORS 
# Development:
FRONTEND_ORIGIN=http://localhost:5173

#  Security 
# DISABLE_RATE_LIMIT=true               # Set to true in development to disable rate limiting
# BEHIND_PROXY=false                    # Set to true if behind reverse proxy (ALB, nginx)

#  Internal API (Edge ↔ Origin communication) 
INTERNAL_API_KEY=broadclass-internal-key-change-in-production

#  Origin Server 
# PORT=3001
# ANNOUNCED_IP=127.0.0.1                # Set to EC2 public IP in production
# RTC_MIN_PORT=40000
# RTC_MAX_PORT=40099
# NUM_WORKERS=4
# ENABLE_SIMULCAST=true
# MAX_BROADCASTERS=10

#  Edge Server 
# PORT=3002
# EXTERNAL_PORT=3002
# INTERNAL_HOST=localhost
# SERVER_ID=EDGE-01                     # Unique per edge instance
# ANNOUNCED_IP=127.0.0.1                # Set to EC2 public IP in production
# ORIGIN_IP=localhost                   # Origin EC2 private IP in production
# ORIGIN_PORT=3001
# RTC_MIN_PORT=50000
# RTC_MAX_PORT=50099
# NUM_WORKERS=2
# MAX_CAPACITY=300                      # ~300 viewers per c5.large
# HEALTH_CHECK_INTERVAL=10000
# REGION=us-east-1

#  Auto-Scaling (Origin only, AWS ASG) 
# AUTO_SCALE_ENABLED=false
# AUTO_SCALE_MIN_EDGES=2
# AUTO_SCALE_MAX_EDGES=10
# AUTO_SCALE_UP_THRESHOLD=70            # % capacity → add edge
# AUTO_SCALE_DOWN_THRESHOLD=20          # % capacity → remove edge (if all below)
# AUTO_SCALE_CHECK_INTERVAL=30000       # ms between checks
# AUTO_SCALE_COOLDOWN_UP=60000          # ms cooldown after scale-up
# AUTO_SCALE_COOLDOWN_DOWN=120000       # ms cooldown after scale-down

#  AWS Auto Scaling 
# Note: AWS credentials via IAM role on EC2
# AWS_ASG_NAME=broadclass-edge-asg
# AWS_REGION=ap-south-1


# recordings
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_PREFIX=recordings                 