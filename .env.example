# Docker Compose Environment
# Your machine's LAN IP (used for WebRTC ANNOUNCED_IP)
ANNOUNCED_IP=10.189.167.230

# Redis URL (replace with your Upstash URL)
REDIS_URL="rediss://default:your-password@your-host.upstash.io:6379"

# Node environment
NODE_ENV=development

# Database URL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT Auth
JWT_SECRET=<JWT_SECRET>

# Frontend CORS origin
FRONTEND_ORIGIN=http://localhost:5173

# Internal API key (Edge ↔ Origin)
INTERNAL_API_KEY=<INTERNAL_API_KEY>

# Logging level
LOG_LEVEL=info

# S3 Recording
S3_BUCKET=<BUCKET_NAME>
S3_REGION=ap-south-1
S3_ACCESS_KEY=<ACCESS_KEY>
S3_SECRET_KEY=<SECRET_KEY>
S3_PREFIX=recordings            


#  Auto-Scaling (optional)
# AUTO_SCALE_MIN_EDGES=2
# AUTO_SCALE_MAX_EDGES=10
# LOG_LEVEL=info


# ─────────────────────────────────────────────────────────────────────
# Smart Chat (Live Transcription + RAG)
# Required from Phase 1 onward. Phase 0 starts the ai-service without
# these and reports them as "not configured" via the /health endpoint.
# ─────────────────────────────────────────────────────────────────────

# Deepgram (streaming speech-to-text). Get a key at https://console.deepgram.com/
DEEPGRAM_API_KEY=<DEEPGRAM_API_KEY>

# Groq (LLM for answers + moderation). Free tier; get a key at https://console.groq.com/
GROQ_API_KEY=<GROQ_API_KEY>

# Internal URL for the ai-service. Docker Compose default is fine; override
# only if running outside compose or against a remote ai-service.
AI_SERVICE_INTERNAL_URL=http://ai-service:8080

# Model selection (defaults match what we tested with — change at your own risk).
# ANSWER_MODEL_PRIMARY=llama-3.3-70b-versatile
# ANSWER_MODEL_FALLBACK=llama-3.1-8b-instant
# MODERATION_MODEL=llama-3.1-8b-instant
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
