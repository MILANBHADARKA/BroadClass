# Docker Compose Environment
# Your machine's LAN IP (used for WebRTC ANNOUNCED_IP)
ANNOUNCED_IP=10.189.167.230

# Redis URL (replace with your Upstash URL)
REDIS_URL="rediss://default:your-password@your-host.upstash.io:6379"

# Node environment
NODE_ENV=development

# Database URL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT Auth
JWT_SECRET=<JWT_SECRET>

# Frontend CORS origin
FRONTEND_ORIGIN=http://localhost:5173

# Internal API key (Edge ↔ Origin)
INTERNAL_API_KEY=<INTERNAL_API_KEY>

# Logging level
LOG_LEVEL=info

# S3 Recording
S3_BUCKET=<BUCKET_NAME>
S3_REGION=ap-south-1
S3_ACCESS_KEY=<ACCESS_KEY>
S3_SECRET_KEY=<SECRET_KEY>
S3_PREFIX=recordings            


#  Auto-Scaling (optional)
# AUTO_SCALE_MIN_EDGES=2
# AUTO_SCALE_MAX_EDGES=10
# LOG_LEVEL=info


# Smart Chat (Live Transcription + RAG)
AI_SERVICE_INTERNAL_URL=http://ai-service:8080

# Each layer is independent — change a value and restart ai-service.
# Only API keys for the providers you SELECT need to be populated.
#
# Supported values:
#   STT_PROVIDER:        deepgram
#   EMBEDDING_PROVIDER:  sentence_transformers | openai
#   ANSWER_PROVIDER:     groq | openai | anthropic
#   MODERATION_PROVIDER: groq | openai
STT_PROVIDER=deepgram
EMBEDDING_PROVIDER=sentence_transformers
ANSWER_PROVIDER=groq
MODERATION_PROVIDER=groq

# Deepgram (streaming STT). Get a key at https://console.deepgram.com/
DEEPGRAM_API_KEY=<DEEPGRAM_API_KEY>

# Groq (free tier — fast LLM inference). https://console.groq.com/
GROQ_API_KEY=<GROQ_API_KEY>

# OpenAI (only required if you set ANSWER_PROVIDER / MODERATION_PROVIDER /
# EMBEDDING_PROVIDER to "openai"). https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (only required if ANSWER_PROVIDER=anthropic).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Model selection (per provider — defaults are fine for most users)
# Groq:
# ANSWER_MODEL_PRIMARY=llama-3.3-70b-versatile
# ANSWER_MODEL_FALLBACK=llama-3.1-8b-instant
# MODERATION_MODEL=llama-3.1-8b-instant
# OpenAI:
# OPENAI_ANSWER_MODEL=gpt-4o-mini
# OPENAI_MODERATION_MODEL=omni-moderation-latest
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small      # supports 384-dim via API
# Anthropic:
# ANTHROPIC_ANSWER_MODEL=claude-haiku-4-5-20251001
# Local embedding model (sentence_transformers provider):
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# How to switch providers
# Example — use OpenAI for everything:
#   ANSWER_PROVIDER=openai
#   MODERATION_PROVIDER=openai
#   EMBEDDING_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
# Then: docker compose restart ai-service
#
# Example — use Anthropic for answers, keep Groq for moderation:
#   ANSWER_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-...
# (Groq key already set, MODERATION_PROVIDER stays at groq.)
