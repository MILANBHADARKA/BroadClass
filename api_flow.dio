                <mxCell id="socketSys" value="System Manager Socket.IO:&#xa;&#xa;Server → Client:&#xa;- broadcast:started / :ended&#xa;- recording:started / :stopped&#xa;- recording:progress&#xa;- viewer:count&#xa;- chat:message&#xa;- chat:status-update&#xa;- transcription:chunk&#xa;&#xa;Client → Server:&#xa;- chat:join-room { sessionId }&#xa;- chat:leave-room { sessionId }&#xa;- chat:send { sessionId, content }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9C27B0;align=left;spacingLeft=10;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="310" y="1085" width="350" height="260" as="geometry"/>
